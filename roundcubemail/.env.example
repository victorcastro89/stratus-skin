# External IMAP Server Configuration
IMAP_HOST=your-imap-server.com
IMAP_PORT=993
IMAP_SSL=ssl

# External SMTP Server Configuration
SMTP_HOST=your-smtp-server.com
SMTP_PORT=587
SMTP_SSL=tls
SMTP_USER=%u
SMTP_PASS=%p

# Roundcube Configuration
ROUNDCUBE_DEFAULT_HOST=ssl://your-imap-server.com
ROUNDCUBE_DEFAULT_PORT=993
ROUNDCUBE_SMTP_SERVER=tls://your-smtp-server.com
ROUNDCUBE_SMTP_PORT=587

# Product name
ROUNDCUBE_PRODUCT_NAME=Roundcube Webmail Dev

# Support URL
ROUNDCUBE_SUPPORT_URL=https://github.com/roundcube/roundcubemail

# Skin (for development)
ROUNDCUBE_SKIN=elastic
