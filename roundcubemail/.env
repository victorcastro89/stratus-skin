# -------------------------------------------------------
# Local mail server (docker-mailserver)
# -------------------------------------------------------
IMAP_HOST=mailserver
IMAP_PORT=143
IMAP_SSL=

SMTP_HOST=mailserver
SMTP_PORT=25
SMTP_SSL=

# Mail domain
MAIL_DOMAIN=example.test

# Test accounts (created by ./setup-mail.sh)
#   alice@example.test / password123
#   bob@example.test   / password123

# -------------------------------------------------------
# Roundcube Configuration
# -------------------------------------------------------
ROUNDCUBE_DEFAULT_HOST=mailserver
ROUNDCUBE_DEFAULT_PORT=143
ROUNDCUBE_SMTP_SERVER=mailserver
ROUNDCUBE_SMTP_PORT=25
ROUNDCUBE_PRODUCT_NAME=Roundcube Webmail Dev
ROUNDCUBE_SUPPORT_URL=https://github.com/roundcube/roundcubemail

# Skin (for development)
ROUNDCUBE_SKIN=elastic
