# Roundcube → IMAP / SMTP (internal Docker service name)
# Uses the Docker service name so container-to-container routing works
ROUNDCUBEMAIL_DEFAULT_HOST=mailserver
ROUNDCUBEMAIL_DEFAULT_PORT=143
ROUNDCUBEMAIL_SMTP_SERVER=mailserver
ROUNDCUBEMAIL_SMTP_PORT=587

# Roundcube → General
ROUNDCUBEMAIL_DB_TYPE=sqlite
ROUNDCUBEMAIL_SKIN=stratus
ROUNDCUBEMAIL_UPLOAD_MAX_FILESIZE=25M
ROUNDCUBEMAIL_PRODUCT_NAME=Stratus Webmail (Local)
ROUNDCUBEMAIL_SUPPORT_URL=https://github.com/roundcube/roundcubemail

# Roundcube → Plugins
ROUNDCUBEMAIL_COMPOSER_PLUGINS=kolab/calendar
ROUNDCUBEMAIL_PLUGINS=calendar
