{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch & Compile Stratus LESS",
      "type": "shell",
      "command": "npm run less:watch",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "LESS Watch"
      },
      "problemMatcher": {
        "owner": "lessc",
        "fileLocation": "absolute",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "."
        },
        "pattern": {
          "regexp": "^(.+) in (.+) on line (\\d+), column (\\d+):$",
          "message": 1,
          "file": 2,
          "line": 3,
          "column": 4
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Compile Stratus LESS (once)",
      "type": "shell",
      "command": "npm run less:build",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": {
        "owner": "lessc",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(.+) in (.+) on line (\\d+), column (\\d+):$",
          "message": 1,
          "file": 2,
          "line": 3,
          "column": 4
        }
      }
    }
  ]
}
