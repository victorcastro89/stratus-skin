# ====================================================================
# Stratus Skin Project — .gitignore
# ====================================================================
# This repo only tracks: our custom skins, plugins, Docker setup,
# config templates, build tooling, and AI agent system.
# The upstream Roundcube source is a local git clone (roundcubemail/),
# always ignored by this repository.
# ====================================================================

# ── Upstream Roundcube (standalone clone — not tracked here) ─────────

# ── Generated / runtime files ──────────────────────────────────────────
node_modules/
*.min.css
!skins/*/styles/styles.min.css

# ── Compiled CSS (rebuild with `npm run less:build`) ───────────────────
skins/*/styles/styles.css

# ── Secrets & local config ─────────────────────────────────────────────
docker/.env
roundcubemail/

# ── Docker host-mounted volumes (Roundcube web root + SQLite DB) ───────
docker/www/
docker/db/

# ── OS / editor junk ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Stale artifacts from pre-restructure ──────────────────────────────
config.inc.php
config.inc copy.php
roundcubemail.worktrees/
README_CALDAV.md
